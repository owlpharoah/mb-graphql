  "query": "SELECT\n                la.label,\n                la.name,\n                la.sort_name,\n                at.name AS type_name,\n                la.locale,\n                la.primary_for_locale,\n                la.begin_date_year,\n                la.begin_date_month,\n                la.begin_date_day,\n                la.end_date_year,\n                la.end_date_month,\n                la.end_date_day,\n                la.ended\n            FROM label_alias la\n            LEFT JOIN label_alias_type at ON at.id = la.\"type\"\n            WHERE la.label = ANY($1)",

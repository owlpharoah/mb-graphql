  "query": "SELECT\n                    aa.area,\n                    aa.name,\n                    aa.sort_name,\n                    at.name AS type_name,\n                    aa.locale,\n                    aa.primary_for_locale,\n                    aa.begin_date_year,\n                    aa.begin_date_month,\n                    aa.begin_date_day,\n                    aa.end_date_year,\n                    aa.end_date_month,\n                    aa.end_date_day,\n                    aa.ended\n                FROM area_alias aa\n                LEFT JOIN area_alias_type at ON at.id = aa.\"type\"\n                WHERE aa.area = ANY($1)",

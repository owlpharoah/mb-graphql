  "query": "SELECT\n                ra.release,\n                ra.name,\n                ra.sort_name,\n                at.name AS type_name,\n                ra.locale,\n                ra.primary_for_locale,\n                ra.begin_date_year,\n                ra.begin_date_month,\n                ra.begin_date_day,\n                ra.end_date_year,\n                ra.end_date_month,\n                ra.end_date_day,\n                ra.ended\n            FROM release_alias ra\n            LEFT JOIN release_alias_type at ON at.id = ra.\"type\"\n            WHERE ra.release = ANY($1)",
